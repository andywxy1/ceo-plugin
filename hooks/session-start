#!/usr/bin/env bash
# SessionStart hook for CEO plugin
# Injects CEO awareness into every conversation so the AI knows when to suggest /ceo

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Escape string for JSON embedding using bash parameter substitution
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# Build the awareness context - lightweight, not the full SKILL.md
awareness_content="You have access to the CEO (Chief Executive Orchestrator) plugin via /ceo.

The CEO coordinates 170+ specialized AI agents across engineering, design, marketing, sales, and more.

## When to Suggest /ceo

Suggest '/ceo' to the user when you detect:
- Multi-domain projects (engineering + design + marketing + sales)
- Complex coordination needs across 3+ specialized areas
- Projects requiring structured discovery, planning, and agent orchestration
- Strategic initiatives where the right agents and their sequencing aren't obvious
- Any project that would benefit from quality gates, handoff protocols, and phased execution

## When NOT to Suggest /ceo

Do NOT suggest /ceo for:
- Single-domain tasks (just coding, just writing, just debugging)
- Quick questions or simple requests
- Tasks that a single specialist agent can handle
- When the user is already using /ceo in this conversation

## How to Suggest

When you detect a multi-domain task, say something like:
'This looks like a multi-domain project that could benefit from structured orchestration. Would you like me to activate the CEO (/ceo) to coordinate the right agents?'

Do NOT auto-activate. Only suggest. The user decides."

awareness_escaped=$(escape_for_json "$awareness_content")
session_context="<ceo-awareness>\n${awareness_escaped}\n</ceo-awareness>"

# Output context injection as JSON
cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
